{
  "compilerOptions": {
    // 包含的文件模式，用于指定需要编译的文件
    "types": ["node"],
    // 设定编译后的 JavaScript 文件使用的模块化方案
    "module": "commonjs",
    // 设定编译后的 JavaScript 文件的 ECMAScript 目标版本
    "target": "ES2023",
    // 模块加载兼容模式,可以使用 import from 语法导入 commonJS 模块
    "esModuleInterop": true,
    // 生成相应的 .d.ts 文件，用于类型声明
    "declaration": true,
    // 移除编译后文件中的注释
    "removeComments": true,
    // 启用装饰器元数据生成，支持 reflect-metadata
    "emitDecoratorMetadata": true,
    // 启用实验性的装饰器特性
    "experimentalDecorators": true,
    // 允许从没有默认导出的模块中默认导入
    "allowSyntheticDefaultImports": true,
    // 允许导入 JSON 模块
    "resolveJsonModule": true,
    // 生成源映射文件，便于调试（将编译后的JS代码映射回原始TS代码）
    "sourceMap": false,
    // 指定编译输出目录
    "outDir": "./dist",
    // 模块名到基于 baseUrl 的路径映射的列表，这里将 @/* 映射到 src/*，方便路径导入
    "paths": { "@/*": ["./src/*"] },
    // 启用增量编译，只重新编译修改过的文件，提高编译速度
    "incremental": true,
    // 跳过对声明文件（.d.ts）的类型检查，提高编译性能
    "skipLibCheck": true,
    // 启用严格的 null 检查，不允许 null/undefined 赋值给非 null/undefined 类型的变量
    "strictNullChecks": true,
    // 强制文件名称大小写一致，避免在不区分大小写的文件系统中出现问题
    "forceConsistentCasingInFileNames": true,
    // 禁用隐式 any 类型检查，允许变量类型被隐式推断为 any
    "noImplicitAny": false,
    // 禁用严格的 bind/call/apply 方法检查，允许参数类型不严格匹配
    "strictBindCallApply": false,
    // 禁用 switch 语句贯穿检查，允许 case 分支不以 break/return 结束而继续执行下一分支
    "noFallthroughCasesInSwitch": false,
    // 禁用严格的属性初始化检查，允许在类中未初始化属性
    "strictPropertyInitialization": false
  }
}
